---
import type { SpaProduct } from '../data/spaProducts';
import { logoImage, spaProductBySlug } from '../data/spaProducts';

interface Props {
  product: SpaProduct;
}

const { product } = Astro.props;
const relatedProducts = product.related
  .map((item) => ({ ...item, full: spaProductBySlug[item.slug] }))
  .filter((item) => item.full);
---

<nav>
  <a href="/" class="nav-logo">
    <img src={logoImage} alt="Family Pool & Spa" />
  </a>
  <ul class="nav-links">
    <li><a href="/#spas">Shop Spas</a></li>
    <li><a href="/#services">Services</a></li>
    <li><a href="/#reviews">Reviews</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
  <a href="tel:2089397665" class="nav-cta">Call (208) 939-7665</a>
  <button class="nav-hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="breadcrumb-bar">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/#spas">Spas</a>
    <span class="breadcrumb-sep">›</span>
    <a href="#">Island Elite Series</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">{product.name}</span>
  </nav>
</div>

<div class="product-hero">
  <div class="gallery anim-up d1">
    <div class="gallery-main" id="mainImg">
      <img src={product.gallery[0]} alt={product.heroAlt} id="mainImgEl" loading="eager" fetchpriority="high" />
      <div class="img-badges">
        <span class="img-badge badge-energy">ENERGY STAR</span>
        <span class="img-badge badge-usa">★ Made in USA</span>
      </div>
      <div class="gallery-zoom-hint">View larger</div>
    </div>

    <div class="gallery-thumbs" id="thumbs">
      {
        product.gallery.map((image, i) => (
          <div class={`thumb ${i === 0 ? 'active' : ''}`} data-src={image}>
            <img src={image} alt={`${product.name} view ${i + 1}`} loading="lazy" />
          </div>
        ))
      }
    </div>
  </div>

  <div class="product-info">
    <p class="product-eyebrow anim-up d1">{product.series}</p>
    <h1 class="product-name anim-up d2">{product.name}</h1>
    <p class="product-series anim-up d2">{product.model}</p>

    <div class="spec-pills anim-up d3">
      <div class="spec-pill">{product.quickSpecs.seats}</div>
      <div class="spec-pill">{product.quickSpecs.jets}</div>
      <div class="spec-pill">{product.quickSpecs.dimensions}</div>
      <div class="spec-pill">{product.quickSpecs.gallons}</div>
      <div class="spec-pill">ENERGY STAR</div>
    </div>

    <div class="product-price-row anim-up d3">
      <div class="product-price">{product.startingPrice}</div>
      <div class="product-price-note">starting price · delivery & install available</div>
    </div>

    <div class="anim-up d4">
      <p class="picker-label">
        Shell Color — <span class="picker-selected" id="shellLabel">{product.shellColors[0].name}</span>
      </p>
      <div class="color-swatches" id="shellSwatches">
        {
          product.shellColors.map((swatch, i) => (
            <div
              class={`swatch ${i === 0 ? 'active' : ''}`}
              data-name={swatch.name}
              style={`background: ${swatch.gradient}`}
              title={swatch.name}
            />
          ))
        }
      </div>

      <p class="picker-label" style="margin-top:8px">
        Cabinet — <span class="picker-selected" id="cabinetLabel">{product.cabinetColors[0].name}</span>
      </p>
      <div class="color-swatches" id="cabinetSwatches">
        {
          product.cabinetColors.map((swatch, i) => (
            <div
              class={`swatch ${i === 0 ? 'active' : ''}`}
              data-name={swatch.name}
              style={`background: ${swatch.gradient}`}
              title={swatch.name}
            />
          ))
        }
      </div>
    </div>

    <div class="cta-stack anim-up d5">
      <a href="/#contact" class="btn-primary">Request a Quote on This Model</a>
      <a href="tel:2089397665" class="btn-secondary">Call (208) 939-7665</a>
    </div>

    <div class="trust-micro anim-up d5">
      <div class="trust-micro-item"><strong>Lifetime</strong>Structural Warranty</div>
      <div class="trust-micro-item"><strong>In-House</strong>Installation Team</div>
      <div class="trust-micro-item"><strong>Free</strong>Water Analysis</div>
    </div>
  </div>
</div>

<div class="product-content">
  <div class="tab-nav" role="tablist">
    <button class="tab-btn active" role="tab" data-tab="features">Features</button>
    <button class="tab-btn" role="tab" data-tab="specs">Specifications</button>
    <button class="tab-btn" role="tab" data-tab="warranty">Warranty</button>
  </div>

  <div class="tab-panel active" id="tab-features">
    <div class="features-grid">
      {
        product.features.map((feature) => (
          <div class="feature-card">
            <p class="feature-tag">{feature.tag}</p>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))
      }
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;padding:40px;background:var(--panel);border:1px solid var(--border);border-radius:12px">
      <div>
        <p class="section-eyebrow">Signature Feature</p>
        <h3 style="font-family:var(--font-display);font-size:clamp(36px,4vw,52px);color:#fff;line-height:1;margin-bottom:14px">
          {product.signature.title}
        </h3>
        <p style="font-size:15px;color:var(--muted);line-height:1.7;max-width:420px">{product.signature.description}</p>
        <div style="display:flex;gap:20px;margin-top:24px">
          {
            product.signature.stats.map((stat) => (
              <div style="text-align:center">
                <div style="font-family:var(--font-display);font-size:44px;color:var(--accent2);line-height:1">{stat.value}</div>
                <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em">{stat.label}</div>
              </div>
            ))
          }
        </div>
      </div>
      <div style="border-radius:10px;overflow:hidden;aspect-ratio:4/3">
        <img src={product.signature.image} alt={`${product.name} signature seat`} style="width:100%;height:100%;object-fit:cover" loading="lazy" />
      </div>
    </div>
  </div>

  <div class="tab-panel" id="tab-specs">
    <div class="specs-layout">
      <div>
        {
          product.specSections.map((section) => (
            <>
              <h3 class="specs-section-title">{section.title}</h3>
              <table class="specs-table">
                <tbody>
                  {section.rows.map(([left, right]) => <tr><td>{left}</td><td>{right}</td></tr>)}
                </tbody>
              </table>
            </>
          ))
        }
      </div>

      <div>
        <div class="specs-diagram">
          <img src={product.gallery[1] ?? product.gallery[0]} alt={`${product.name} top-down view`} loading="lazy" />
          <div class="specs-diagram-overlay"></div>
          <p class="specs-diagram-label">{product.specDiagramLabel}</p>
        </div>

        <div class="spec-highlight-grid">
          {
            product.specHighlights.map((highlight) => (
              <div class="spec-highlight">
                <div class="spec-highlight-num">{highlight.value}</div>
                <div class="spec-highlight-label">{highlight.label}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="tab-panel" id="tab-warranty">
    <div style="margin-bottom:32px">
      <p class="section-eyebrow">Artesian Spas</p>
      <h3 style="font-family:var(--font-display);font-size:clamp(40px,5vw,60px);color:#fff;line-height:1;margin-bottom:12px">The Industry's<br />Strongest Warranty</h3>
      <p style="font-size:15px;color:var(--muted);max-width:600px;line-height:1.7">Most competitors offer 5 years on the shell structure. Artesian offers forever.</p>
    </div>
    <div class="warranty-note">
      <div>
        <strong style="color:var(--text);display:block;margin-bottom:4px">Local warranty service through Family Pool & Spa.</strong>
        As your authorized dealer in Boise, we handle warranty claims directly.
      </div>
    </div>
  </div>
</div>

<section class="related-section">
  <div class="related-inner">
    <p class="section-eyebrow">You May Also Like</p>
    <h2 class="section-h2" style="margin-bottom:0">More Artesian Models</h2>

    <div class="related-grid">
      {
        relatedProducts.map((item) => (
          <a href={`/spas/${item.slug}`} class="related-card">
            <div class="related-card-img">
              <img src={item.image} alt={item.name} loading="lazy" />
              <div class="related-card-overlay"></div>
            </div>
            <div class="related-card-body">
              <div class="related-card-series">{item.series}</div>
              <div class="related-card-name">{item.name}</div>
              <div class="related-card-meta">{item.meta}</div>
              <div class="related-card-price">{item.priceLabel}</div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<div class="mobile-sticky">
  <a href="tel:2089397665" class="ms-call">Call</a>
  <a href="/#contact" class="ms-quote">Request a Quote on This Model →</a>
</div>
