---
import { getSpaProducts } from '../lib/productsData';
import HeaderHero from './home/HeaderHero.astro';
import CollectionsSection from './home/CollectionsSection.astro';
import MarketingSections from './home/MarketingSections.astro';
import ContactFooter from './home/ContactFooter.astro';

const spaProducts = await getSpaProducts();
const preferredOrder = ['mystique', 'bimini', 'isla-margarita', 'grand-cayman', 'grand-bahama', 'antigua', 'captiva', 'nevis', 'santa-cruz'];
const orderIndex = new Map(preferredOrder.map((slug, index) => [slug, index]));

const orderedProducts = [...spaProducts]
  .filter((product) => product.gallery.length > 0)
  .sort((a, b) => {
    const aOrder = orderIndex.get(a.slug) ?? Number.MAX_SAFE_INTEGER;
    const bOrder = orderIndex.get(b.slug) ?? Number.MAX_SAFE_INTEGER;
    if (aOrder !== bOrder) return aOrder - bOrder;
    return a.name.localeCompare(b.name);
  });

const featuredProduct = orderedProducts[0];
const primaryCards = orderedProducts.slice(1, 5);
const secondaryCards = orderedProducts.slice(5, 11);
const seriesLabel = (series: string) => series.split('·')[0].trim();
---

<HeaderHero />
<CollectionsSection
  featuredProduct={featuredProduct}
  primaryCards={primaryCards}
  secondaryCards={secondaryCards}
  seriesLabel={seriesLabel}
/>
<MarketingSections />
<ContactFooter />
