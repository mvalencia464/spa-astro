<!-- ─── SERVICES ──────────────────────────────────────────────── -->
<section class="section reviews-section" id="services">
  <div class="section-inner">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:end;margin-bottom:0">
      <div>
        <p class="section-label">What We Do</p>
        <h2 class="section-h2">Full Service.<br/>Start to Finish.</h2>
      </div>
      <p class="section-sub" style="margin-bottom:0">From choosing your spa to keeping the water perfect — we handle every step so you don't have to figure it out alone.</p>
    </div>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-num">01</div>
        <div class="service-icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="service-title">Spa Sales</h3>
        <p class="service-desc">Wet demos, no-haggle pricing, and a team that actually knows every model. Come test before you buy — on-site, in the water.</p>
      </div>

      <div class="service-card">
        <div class="service-num">02</div>
        <div class="service-icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <h3 class="service-title">Water Analysis</h3>
        <p class="service-desc">Free computerized water testing. Bring in a sample and we'll tell you exactly what your water needs — no upsell, no guesswork.</p>
      </div>

      <div class="service-card">
        <div class="service-num">03</div>
        <div class="service-icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
          </svg>
        </div>
        <h3 class="service-title">Service & Repair</h3>
        <p class="service-desc">Heaters, pumps, control boards, leak detection. Factory-trained techs who answer the phone — and actually show up when they say they will.</p>
      </div>

      <div class="service-card">
        <div class="service-num">04</div>
        <div class="service-icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="service-title">Seasonal Service</h3>
        <p class="service-desc">Boise winters are no joke. We handle pool openings, closings, winterizing, and cover protection — so your equipment survives the freeze.</p>
      </div>

      <div class="service-card">
        <div class="service-num">05</div>
        <div class="service-icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
          </svg>
        </div>
        <h3 class="service-title">Pool Cleaning</h3>
        <p class="service-desc">Vacuuming, brushing, chemical balancing, and filter maintenance on a schedule that works for your pool — biweekly, monthly, or as-needed.</p>
      </div>

      <div class="service-card">
        <div class="service-num">06</div>
        <div class="service-icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="service-title">Delivery & Install</h3>
        <p class="service-desc">Full white-glove delivery and placement. We coordinate electrical, level your pad, and walk you through startup — first soak is same day.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── REVIEWS ────────────────────────────────────────────────── -->
<section class="section" id="reviews" style="background:var(--deep)">
  <div class="section-inner">
