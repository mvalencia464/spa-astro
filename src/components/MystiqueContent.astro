---

<!-- ─── NAV ──────────────────────────────────────────── -->
<nav>
  <a href="/" class="nav-logo">
    <img src="https://media.stokeleads.com/test/logo.webp" alt="Family Pool & Spa"/>
  </a>
  <ul class="nav-links">
    <li><a href="/#spas">Shop Spas</a></li>
    <li><a href="/#services">Services</a></li>
    <li><a href="/#reviews">Reviews</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
  <a href="tel:2089397665" class="nav-cta">Call (208) 939-7665</a>
  <button class="nav-hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- ─── BREADCRUMB ────────────────────────────────────── -->
<div class="breadcrumb-bar">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/#spas">Spas</a>
    <span class="breadcrumb-sep">›</span>
    <a href="#">Prestige Series</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">Mystique</span>
  </nav>
</div>

<!-- ─── PRODUCT HERO ──────────────────────────────────── -->
<div class="product-hero">

  <!-- LEFT: Gallery -->
  <div class="gallery anim-up d1">
    <div class="gallery-main" id="mainImg">
      <img src="https://media.stokeleads.com/spas/island-elite/2025_20Bimini_20Elite.webp" alt="Artesian Mystique Hot Tub" id="mainImgEl" loading="eager" fetchpriority="high"/>
      <div class="img-badges">
        <span class="img-badge badge-energy">
          <svg width="10" height="10" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          ENERGY STAR
        </span>
        <span class="img-badge badge-usa">
          ★ Made in USA
        </span>
      </div>
      <div class="gallery-zoom-hint">
        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 8v6M8 11h6"/></svg>
        View larger
      </div>
    </div>

    <div class="gallery-thumbs" id="thumbs">
      <div class="thumb active" data-src="https://media.stokeleads.com/spas/island-elite/2025_20Bimini_20Elite.webp">
        <img src="https://media.stokeleads.com/spas/island-elite/2025_20Bimini_20Elite.webp" alt="Mystique front view" loading="lazy"/>
      </div>
      <div class="thumb" data-src="https://media.stokeleads.com/spas/island-elite/2025_20Bimini_Black_Side_20View.webp">
        <img src="https://media.stokeleads.com/spas/island-elite/2025_20Bimini_Black_Side_20View.webp" alt="Alternate view" loading="lazy"/>
      </div>
      <div class="thumb" data-src="https://media.stokeleads.com/spas/island-elite/2025_20Captiva_Elite.webp">
        <img src="https://media.stokeleads.com/spas/island-elite/2025_20Captiva_Elite.webp" alt="Interior jets" loading="lazy"/>
      </div>
      <div class="thumb" data-src="https://media.stokeleads.com/spas/island-elite/2025_20Antigua_Elite.webp">
        <img src="https://media.stokeleads.com/spas/island-elite/2025_20Antigua_Elite.webp" alt="Cabinet detail" loading="lazy"/>
      </div>
      <div class="thumb" data-src="https://media.stokeleads.com/spas/island-elite/2022_IslandSpas_TranquilityFall.webp">
        <img src="https://media.stokeleads.com/spas/island-elite/2022_IslandSpas_TranquilityFall.webp" alt="Lifestyle" loading="lazy"/>
      </div>
    </div>
  </div>

  <!-- RIGHT: Product info -->
  <div class="product-info">

    <p class="product-eyebrow anim-up d1">Prestige Series · Artesian Spas</p>

    <h1 class="product-name anim-up d2">Mystique</h1>
    <p class="product-series anim-up d2">6-Person Hydrotherapy Spa · Model MST-639</p>

    <!-- Quick specs -->
    <div class="spec-pills anim-up d3">
      <div class="spec-pill">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
        6 Seats
      </div>
      <div class="spec-pill">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3"/></svg>
        38 Jets
      </div>
      <div class="spec-pill">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
        84″ × 84″ × 35″
      </div>
      <div class="spec-pill">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        350 Gallons
      </div>
      <div class="spec-pill">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        ENERGY STAR
      </div>
    </div>

    <!-- Price -->
    <div class="product-price-row anim-up d3">
      <div class="product-price">$11,999</div>
      <div class="product-price-note">starting price · delivery & install available</div>
    </div>

    <!-- Shell color picker -->
    <div class="anim-up d4">
      <p class="picker-label">Shell Color — <span class="picker-selected" id="shellLabel">Silver Marble</span></p>
      <div class="color-swatches" id="shellSwatches">
        <div class="swatch active" data-name="Silver Marble"   style="background: linear-gradient(135deg, #c0c8d0, #8898a4)" title="Silver Marble"></div>
        <div class="swatch"        data-name="White Pearl"     style="background: linear-gradient(135deg, #f5f0eb, #e2ddd6)" title="White Pearl"></div>
        <div class="swatch"        data-name="Midnight Canyon" style="background: linear-gradient(135deg, #1a2535, #0e1820)" title="Midnight Canyon"></div>
        <div class="swatch"        data-name="Tuscan Sun"      style="background: linear-gradient(135deg, #c8922a, #a06e1a)" title="Tuscan Sun"></div>
        <div class="swatch"        data-name="Storm"           style="background: linear-gradient(135deg, #4a5568, #2d3748)" title="Storm"></div>
      </div>

      <p class="picker-label" style="margin-top:8px">Cabinet — <span class="picker-selected" id="cabinetLabel">Coastal Gray</span></p>
      <div class="color-swatches" id="cabinetSwatches">
        <div class="swatch active" data-name="Coastal Gray" style="background: linear-gradient(135deg, #6b7a8a, #4a5568)" title="Coastal Gray"></div>
        <div class="swatch"        data-name="Espresso"     style="background: linear-gradient(135deg, #3d2b1f, #2a1d14)" title="Espresso"></div>
        <div class="swatch"        data-name="Teak"         style="background: linear-gradient(135deg, #8b6340, #6b4a2a)" title="Teak"></div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="cta-stack anim-up d5">
      <a href="/#contact" class="btn-primary">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Request a Quote on This Model
      </a>
      <a href="tel:2089397665" class="btn-secondary">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call (208) 939-7665
      </a>
    </div>

    <!-- Micro trust row -->
    <div class="trust-micro anim-up d5">
      <div class="trust-micro-item">
        <strong>Lifetime</strong>
        Structural Warranty
      </div>
      <div class="trust-micro-item">
        <strong>In-House</strong>
        Installation Team
      </div>
      <div class="trust-micro-item">
        <strong>Free</strong>
        Water Analysis
      </div>
    </div>

  </div>
</div>

<!-- ─── TABS + CONTENT ────────────────────────────────── -->
<div class="product-content">
  <div class="tab-nav" role="tablist">
    <button class="tab-btn active" role="tab" data-tab="features">Features</button>
    <button class="tab-btn"        role="tab" data-tab="specs">Specifications</button>
    <button class="tab-btn"        role="tab" data-tab="warranty">Warranty</button>
  </div>

  <!-- FEATURES PANEL -->
  <div class="tab-panel active" id="tab-features">
    <div class="features-grid">

      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547"/></svg>
        </div>
        <p class="feature-tag">Hydrotherapy</p>
        <h3 class="feature-title">SmartJet System</h3>
        <p class="feature-desc">Redirect water flow between jets with a simple twist — concentrate therapy exactly where you need it. Shoulders, lower back, calves. No extra energy cost.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        </div>
        <p class="feature-tag">Filtration</p>
        <h3 class="feature-title">SureFlow Circulation</h3>
        <p class="feature-desc">A dedicated low-watt circulation pump runs 24/7 keeping water crystal clear — without cycling your main pump constantly. Up to 60% lower energy vs. single-pump systems.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        </div>
        <p class="feature-tag">Construction</p>
        <h3 class="feature-title">Everwood HD Cabinet</h3>
        <p class="feature-desc">High-density polyethylene that looks like real wood — without rotting, warping, or fading. Zero maintenance, ever. Built for Idaho winters.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
        </div>
        <p class="feature-tag">Insulation</p>
        <h3 class="feature-title">DualThermal Cover</h3>
        <p class="feature-desc">4-inch tapered foam with a heat-sealed vapor barrier on each half. Retains more heat overnight than any competitor cover at this price — critical for Boise winters.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <p class="feature-tag">Ambiance</p>
        <h3 class="feature-title">LED Perimeter Lighting</h3>
        <p class="feature-desc">Multi-color LED lighting integrated into the shell perimeter and footwell. Controlled from the topside panel. Negligible energy draw — maximum atmosphere.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <p class="feature-tag">Efficiency</p>
        <h3 class="feature-title">Full-Foam Insulation</h3>
        <p class="feature-desc">Every Artesian spa is injected with closed-cell foam — filling every cavity from shell to cabinet. No heat escapes. Saves $50–$100/year vs. partial-foam competitors.</p>
      </div>

    </div>

    <!-- Lounge seat callout -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;padding:40px;background:var(--panel);border:1px solid var(--border);border-radius:12px">
      <div>
        <p class="section-eyebrow">Signature Feature</p>
        <h3 style="font-family:var(--font-display);font-size:clamp(36px,4vw,52px);color:#fff;line-height:1;margin-bottom:14px">Full-Length Lounge Seat</h3>
        <p style="font-size:15px;color:var(--muted);line-height:1.7;max-width:420px">
          The Mystique's contoured lounge seat cradles your entire body from neck to feet — 6 dedicated jets along the spine, 4 at the calves. Most "lounge" seats stop at the knees. This one doesn't.
        </p>
        <div style="display:flex;gap:20px;margin-top:24px">
          <div style="text-align:center">
            <div style="font-family:var(--font-display);font-size:44px;color:var(--accent2);line-height:1">6</div>
            <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em">Spine Jets</div>
          </div>
          <div style="text-align:center">
            <div style="font-family:var(--font-display);font-size:44px;color:var(--accent2);line-height:1">4</div>
            <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em">Calf Jets</div>
          </div>
          <div style="text-align:center">
            <div style="font-family:var(--font-display);font-size:44px;color:var(--accent2);line-height:1">2</div>
            <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em">Foot Jets</div>
          </div>
        </div>
      </div>
      <div style="border-radius:10px;overflow:hidden;aspect-ratio:4/3">
        <img src="https://media.stokeleads.com/spas/island-elite/2025_20Bimini_20Elite.webp" alt="Mystique lounge seat" style="width:100%;height:100%;object-fit:cover" loading="lazy"/>
      </div>
    </div>
  </div>

  <!-- SPECS PANEL -->
  <div class="tab-panel" id="tab-specs">
    <div class="specs-layout">
      <div>
        <h3 class="specs-section-title">Dimensions & Capacity</h3>
        <table class="specs-table">
          <tr><td>Seating Capacity</td><td>6 Adults</td></tr>
          <tr><td>Dimensions (L × W × H)</td><td>84″ × 84″ × 35″</td></tr>
          <tr><td>Water Capacity</td><td>350 Gallons</td></tr>
          <tr><td>Dry Weight</td><td>680 lbs</td></tr>
          <tr><td>Filled Weight</td><td>3,600 lbs</td></tr>
          <tr><td>Cover Weight</td><td>60 lbs</td></tr>
        </table>

        <h3 class="specs-section-title" style="margin-top:36px">Jet System</h3>
        <table class="specs-table">
          <tr><td>Total Jets</td><td>38 Jets</td></tr>
          <tr><td>Lounge Jets</td><td>12 (SmartJet)</td></tr>
          <tr><td>Therapy Seat Jets</td><td>16 (directional)</td></tr>
          <tr><td>Foot Jets</td><td>6</td></tr>
          <tr><td>Neck &amp; Shoulder</td><td>4 (rotational)</td></tr>
          <tr><td>Jet Technology</td><td>SmartJet™ Hydrotherapy</td></tr>
        </table>

        <h3 class="specs-section-title" style="margin-top:36px">Electrical</h3>
        <table class="specs-table">
          <tr><td>Voltage</td><td>240V / 60Hz</td></tr>
          <tr><td>Amperage</td><td>50 Amps (GFCI required)</td></tr>
          <tr><td>Main Pump</td><td>2.5 HP, 2-speed</td></tr>
          <tr><td>Circulation Pump</td><td>SureFlow™ 0.15 HP</td></tr>
          <tr><td>Heater</td><td>5.5 kW Titanium</td></tr>
          <tr><td>ENERGY STAR Certified</td><td>Yes</td></tr>
        </table>
      </div>

      <div>
        <div class="specs-diagram">
          <img src="https://media.stokeleads.com/spas/island-elite/2025_20Bimini_20Elite.webp" alt="Mystique top-down view" loading="lazy"/>
          <div class="specs-diagram-overlay"></div>
          <p class="specs-diagram-label">Mystique · MST-639 · 84″ × 84″</p>
        </div>

        <div class="spec-highlight-grid">
          <div class="spec-highlight">
            <div class="spec-highlight-num">38</div>
            <div class="spec-highlight-label">Total Jets</div>
          </div>
          <div class="spec-highlight">
            <div class="spec-highlight-num">350</div>
            <div class="spec-highlight-label">Gallons</div>
          </div>
          <div class="spec-highlight">
            <div class="spec-highlight-num">104°</div>
            <div class="spec-highlight-label">Max Temp</div>
          </div>
          <div class="spec-highlight">
            <div class="spec-highlight-num">6</div>
            <div class="spec-highlight-label">Seat Positions</div>
          </div>
        </div>

        <h3 class="specs-section-title" style="margin-top:32px">Water Care</h3>
        <table class="specs-table">
          <tr><td>Filtration</td><td>SureFlow™ Continuous</td></tr>
          <tr><td>Filter Type</td><td>Tri-X Weave Cartridge</td></tr>
          <tr><td>Ozone Ready</td><td>Yes (field-installable)</td></tr>
          <tr><td>Water Temperature Range</td><td>60°F – 104°F</td></tr>
          <tr><td>Control System</td><td>Balboa BP Series Topside</td></tr>
          <tr><td>WiFi Control</td><td>Optional (ControlMySpa)</td></tr>
        </table>
      </div>
    </div>
  </div>

  <!-- WARRANTY PANEL -->
  <div class="tab-panel" id="tab-warranty">
    <div style="margin-bottom:32px">
      <p class="section-eyebrow">Artesian Spas</p>
      <h3 style="font-family:var(--font-display);font-size:clamp(40px,5vw,60px);color:#fff;line-height:1;margin-bottom:12px">The Industry's<br/>Strongest Warranty</h3>
      <p style="font-size:15px;color:var(--muted);max-width:600px;line-height:1.7">Most competitors offer 5 years on the shell structure. Artesian offers forever. Because if you build something right, you stand behind it.</p>
    </div>

    <div class="warranty-grid">
      <div class="warranty-card">
        <div class="warranty-duration">∞</div>
        <div>
          <div class="warranty-what">Shell Structure &amp; Surface</div>
          <div class="warranty-covers">Full lifetime coverage on the fiberglass shell structure and shell surface — leaks, cracks, delamination. For as long as you own the spa.</div>
        </div>
      </div>
      <div class="warranty-card">
        <div class="warranty-duration">5<span style="font-size:22px">yr</span></div>
        <div>
          <div class="warranty-what">Plumbing</div>
          <div class="warranty-covers">All plumbing components, fittings, manifolds, and unions. Any leak that isn't caused by physical damage.</div>
        </div>
      </div>
      <div class="warranty-card">
        <div class="warranty-duration">5<span style="font-size:22px">yr</span></div>
        <div>
          <div class="warranty-what">Equipment</div>
          <div class="warranty-covers">Main pumps, circulation pump, heater, control system, jets, and blower under normal operating conditions.</div>
        </div>
      </div>
      <div class="warranty-card">
        <div class="warranty-duration">5<span style="font-size:22px">yr</span></div>
        <div>
          <div class="warranty-what">Cabinet &amp; Cover</div>
          <div class="warranty-covers">Everwood HD cabinet panels and DualThermal cover against manufacturing defects. 3 years on cover hardware.</div>
        </div>
      </div>
    </div>

    <div class="warranty-note">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="margin-top:2px">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <strong style="color:var(--text);display:block;margin-bottom:4px">Local warranty service through Family Pool &amp; Spa.</strong>
        As your authorized Artesian dealer in Boise, we handle warranty claims directly — no shipping your spa across the country, no waiting for a factory rep. Mike and his team come to you.
      </div>
