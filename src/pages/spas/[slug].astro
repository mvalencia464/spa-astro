---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductContent from '../../components/ProductContent.astro';
import '../../styles/mystique.css';
import { getSpaProductBySlug, getSpaProducts } from '../../lib/productsData';

export async function getStaticPaths() {
  const spaProducts = await getSpaProducts();
  return spaProducts.map((product) => ({
    params: { slug: product.slug }
  }));
}

const products = await getSpaProducts();
const spaProductBySlug = Object.fromEntries(products.map((product) => [product.slug, product]));
const product = await getSpaProductBySlug(Astro.params.slug ?? '');

if (!product) {
  throw new Error(`Unknown spa product slug: ${Astro.params.slug}`);
}
---

<BaseLayout
  title={`${product.name} — Island Elite Spas | Family Pool & Spa · Boise, ID`}
  description={`${product.name} hot tub from the Island Elite collection — features, specifications, and warranty details.`}
>
  <ProductContent product={product} spaProductBySlug={spaProductBySlug} />

  <script is:inline>
    const mainImgEl = document.getElementById('mainImgEl');
    const thumbs = [...document.querySelectorAll('.thumb')];
    const prevBtn = document.getElementById('galleryPrevBtn');
    const nextBtn = document.getElementById('galleryNextBtn');

    function preloadImage(url) {
      if (!url) return;
      const img = new Image();
      img.decoding = 'async';
      img.src = url;
    }

    function getActiveIndex() {
      return Math.max(0, thumbs.findIndex((thumb) => thumb.classList.contains('active')));
    }

    function setActiveImage(index) {
      if (!mainImgEl || !thumbs.length) return;
      const total = thumbs.length;
      const normalized = (index + total) % total;
      const activeThumb = thumbs[normalized];
      const src = activeThumb?.dataset?.src;
      if (!src) return;

      mainImgEl.style.opacity = '0';
      setTimeout(() => {
        mainImgEl.src = src;
        mainImgEl.style.opacity = '1';
      }, 160);

      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle('active', i === normalized);
      });

      const nextSrc = thumbs[(normalized + 1) % total]?.dataset?.src;
      preloadImage(nextSrc);
    }

    if (mainImgEl) {
      thumbs.forEach((thumb, i) => {
        thumb.addEventListener('click', () => setActiveImage(i));
      });

      prevBtn?.addEventListener('click', () => setActiveImage(getActiveIndex() - 1));
      nextBtn?.addEventListener('click', () => setActiveImage(getActiveIndex() + 1));

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
        const target = event.target;
        if (target instanceof HTMLElement && ['INPUT', 'TEXTAREA', 'SELECT'].includes(target.tagName)) return;
        if (event.key === 'ArrowLeft') setActiveImage(getActiveIndex() - 1);
        if (event.key === 'ArrowRight') setActiveImage(getActiveIndex() + 1);
      });
    }

    function initSwatches(containerId, labelId) {
      const container = document.getElementById(containerId);
      const label = document.getElementById(labelId);
      if (!container || !label) return;
      container.querySelectorAll('.swatch').forEach((s) => {
        s.addEventListener('click', () => {
          container.querySelectorAll('.swatch').forEach((x) => x.classList.remove('active'));
          s.classList.add('active');
          const name = s.dataset.name;
          if (name) label.textContent = name;
        });
      });
    }
    initSwatches('shellSwatches', 'shellLabel');
    initSwatches('cabinetSwatches', 'cabinetLabel');

    document.querySelectorAll('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        if (!tab) return;
        document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
        btn.classList.add('active');
        const panel = document.getElementById('tab-' + tab);
        if (panel) panel.classList.add('active');
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.style.opacity = '1';
            e.target.style.transform = 'translateY(0)';
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
    );

    document.querySelectorAll('.feature-card, .warranty-card, .related-card, .spec-highlight').forEach((el, i) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = `opacity 0.55s ease ${i * 0.06}s, transform 0.55s cubic-bezier(.16,1,.3,1) ${i * 0.06}s`;
      observer.observe(el);
    });
  </script>
</BaseLayout>
