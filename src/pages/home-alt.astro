---
import BaseLayout from '../layouts/BaseLayout.astro';
import AltHomeContent from '../components/AltHomeContent.astro';
import '../styles/home.css';
---

<BaseLayout
  title="Family Pool & Spa — Expanded Collections"
  description="Alternative homepage with expanded collections and R2 lifestyle gallery."
>
  <AltHomeContent />
  <style>
    .hero-bg {
      background-image: url('https://media.stokeleads.com/spas/island-elite/2025_20Island_20(62).webp');
    }
  </style>
  <script is:inline>
    const nav = document.getElementById('nav');
    if (nav) {
      window.addEventListener(
        'scroll',
        () => {
          nav.classList.toggle('scrolled', window.scrollY > 60);
        },
        { passive: true }
      );
    }

    const heroBg = document.getElementById('heroBg');
    if (heroBg) {
      heroBg.classList.add('loaded');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const canParallax = window.matchMedia('(min-width: 1024px)').matches && !reduceMotion;
      window.addEventListener(
        'scroll',
        () => {
          if (!canParallax) return;
          const y = window.scrollY;
          if (y < window.innerHeight) {
            const parallaxOffset = Math.min(y * 0.035, 24);
            heroBg.style.transform = `scale(1.02) translateY(${parallaxOffset}px)`;
          }
        },
        { passive: true }
      );
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.style.opacity = '1';
            e.target.style.transform = 'translateY(0)';
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.col-card, .review-card, .service-card, .stat-box, .alt-mosaic-item').forEach((el) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s cubic-bezier(.16,1,.3,1)';
      observer.observe(el);
    });

    document.querySelectorAll('.reviews-grid, .services-grid, #moreModels, .alt-mosaic-grid').forEach((grid) => {
      [...grid.children].forEach((child, i) => {
        child.style.transitionDelay = `${i * 0.05}s`;
      });
    });
  </script>
</BaseLayout>
